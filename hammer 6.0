      "source": [
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "from collections import Counter\n",
        "\n",
        "# 1. Preparar dados para plotagem\n",
        "# Criar uma cópia e definir 'timestamp' como índice para plotagem\n",
        "plot_df_ohlcv = df_simulated_ohlcv.copy()\n",
        "plot_df_ohlcv['timestamp'] = pd.to_datetime(plot_df_ohlcv['timestamp'])\n",
        "plot_df_ohlcv.set_index('timestamp', inplace=True)\n",
        "\n",
        "# A curva de capital começa com o capital inicial e depois o capital após cada barra.\n",
        "# Para N barras, há N+1 pontos na curva de capital. Queremos plotar o capital *após* cada barra,\n",
        "# alinhado com o timestamp da barra. O primeiro ponto (capital inicial) não tem um timestamp de barra correspondente.\n",
        "# No entanto, a lógica de backtest começa a calcular trades a partir da barra de índice 2.\n",
        "# O `equity_curve` retornado por `run_backtest` tem `n-1` elementos: `[equity_inicial, equity_apos_barra_2, ..., equity_apos_barra_n-1]`.\n",
        "# Para alinhar com `plot_df_ohlcv` (que tem `n` barras de 0 a n-1), precisamos de `n` pontos.\n",
        "# Preenchemos as duas primeiras barras (0 e 1) com o equity inicial (1.0) já que não há trades nelas.\n",
        "# Ensure result_stress_test is defined (should be after running the previous cell)\n",
        "if 'result_stress_test' not in locals():\n",
        "    print(\"Error: result_stress_test is not defined. Please run the backtest cell first.\")\n",
        "else:\n",
        "    equity_curve_values = [1.0] * 2 + list(result_stress_test.equity_curve[1:])\n",
        "    equity_curve_aligned = pd.Series(equity_curve_values, index=plot_df_ohlcv.index)\n",
        "\n",
        "    # Preparar marcadores de entrada de trade para plotagem na curva de capital\n",
        "    trade_markers_on_equity_idx = [] # índices no plot_df_ohlcv\n",
        "    trade_markers_on_equity_val = [] # valores de capital nesses índices\n",
        "    trade_marker_colors = []\n",
        "\n",
        "    # Coletar dados para o PnL individual de cada trade (para o segundo subplot)\n",
        "    trade_timestamps_for_pnl = []\n",
        "    trade_pnl_values = []\n",
        "    cumulative_pnl_values = []\n",
        "\n",
        "    current_cumulative_r = 0.0\n",
        "    for trade in result_stress_test.trades:\n",
        "        entry_bar_idx = trade.entry_bar\n",
        "        if entry_bar_idx < len(plot_df_ohlcv): # Garantir que o índice da barra esteja dentro dos limites\n",
        "            trade_markers_on_equity_idx.append(entry_bar_idx)\n",
        "            # Usar o valor da curva de capital alinhada para o ponto de entrada\n",
        "            trade_markers_on_equity_val.append(equity_curve_aligned.iloc[entry_bar_idx])\n",
        "\n",
        "            current_cumulative_r += trade.pnl_r\n",
        "            cumulative_pnl_values.append(current_cumulative_r)\n",
        "            trade_pnl_values.append(trade.pnl_r)\n",
        "            trade_timestamps_for_pnl.append(plot_df_ohlcv.index[entry_bar_idx])\n",
        "\n",
        "            if trade.pnl_r > 0:\n",
        "                trade_marker_colors.append('green')\n",
        "            elif trade.pnl_r < 0:\n",
        "                trade_marker_colors.append('red')\n",
        "            else: # Trade não resolvido ou PnL 0\n",
        "                trade_marker_colors.append('orange')\n",
        "\n",
        "\n",
        "    # 2. Plotagem\n",
        "    fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(18, 12), sharex=True, gridspec_kw={'height_ratios': [2, 1]})\n",
        "\n",
        "    # Plot 1: Curva de Capital com Entradas de Trades\n",
        "    ax1.plot(equity_curve_aligned.index, equity_curve_aligned.values, label='Curva de Capital (Teste de Estresse)', color='blue', linewidth=1.5)\n",
        "    ax1.scatter(plot_df_ohlcv.index[trade_markers_on_equity_idx], trade_markers_on_equity_val,\n",
        "                marker='o', s=80, color=trade_marker_colors, zorder=5, label='Entrada de Trade')\n",
        "\n",
        "    ax1.set_title(f'Curva de Capital e Entradas de Trades para {symbol_btc_usd} (Teste de Estresse - Volatilidade {volatility_factor}x)')\n",
        "    ax1.set_ylabel('Multiplicador de Capital')\n",
        "    ax1.grid(True, linestyle='--', alpha=0.7)\n",
        "    ax1.legend()\n",
        "\n",
        "    # Plot 2: PnL Cumulativo por Trade e PnL Individual de Trade (alinhado aos timestamps das entradas de trade)\n",
        "    ax2.plot(trade_timestamps_for_pnl, cumulative_pnl_values, label='PnL Cumulativo (R-múltiplos)', color='orange', linewidth=1.5)\n",
        "    # Plotar PnL individual de trade como barras para melhor visualização\n",
        "    for i, (ts, pnl) in enumerate(zip(trade_timestamps_for_pnl, trade_pnl_values)):\n",
        "        # Calcular largura da barra dinamicamente com base na duração típica da barra (5 minutos)\n",
        "        bar_width = pd.Timedelta(minutes=5)\n",
        "        ax2.bar(ts, pnl, width=bar_width, color='green' if pnl >= 0 else 'red', alpha=0.7)\n",
        "    ax2.set_title('PnL Individual e Cumulativo por Trade')\n",
        "    ax2.set_xlabel('Timestamp')\n",
        "    ax2.set_ylabel('PnL (R-múltiplos)')\n",
        "    ax2.grid(True, linestyle='--', alpha=0.7)\n",
        "    ax2.legend()\n",
        "    plt.xticks(rotation=45)\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "    # 3. Analisar sinais para trades perdedores\n",
        "    losing_trades = [t for t in result_stress_test.trades if t.pnl_r < 0]\n",
        "    signal_component_counts = Counter()\n",
        "    total_losing_trades_with_signals = 0\n",
        "\n",
        "    if result_stress_test.signals is not None:\n",
        "        signals_df_stress = result_stress_test.signals.copy()\n",
        "\n",
        "        for trade in losing_trades:\n",
        "            entry_bar_idx = trade.entry_bar\n",
        "            # Verificar se entry_bar_idx é um índice válido para signals_df_stress\n",
        "            if entry_bar_idx < len(signals_df_stress):\n",
        "                total_losing_trades_with_signals += 1\n",
        "                signal_data = signals_df_stress.iloc[entry_bar_idx]\n",
        "\n",
        "                # Identificar componentes de sinal booleanos ativos\n",
        "                active_signal_components = [\n",
        "                    'hammer', 'shooting_star', 'sweep_low', 'sweep_high', 'killzone',\n",
        "                    'bull_fvg', 'bear_fvg', 'flip_bull', 'flip_bear', 'flow_bull', 'flow_bear'\n",
        "                ]\n",
        "\n",
        "                for key in active_signal_components:\n",
        "                    if key in signal_data and isinstance(signal_data[key], (bool, np.bool_)) and signal_data[key]:\n",
        "                        signal_component_counts[key] += 1\n",
        "\n",
        "    print(\"\\n--- Prevalência de Componentes de Sinal em Trades Perdedores (Teste de Estresse) ---\")\n",
        "    if total_losing_trades_with_signals > 0:\n",
        "        print(f\"Total de Trades Perdedores Analisados: {total_losing_trades_with_signals}\")\n",
        "        for signal, count in signal_component_counts.most_common():\n",
        "            print(f\"  {signal}: {count} vezes ({count / total_losing_trades_with_signals:.1%})\")\n",
        "    else:\n",
        "        print(\"Nenhum trade perdedor encontrado com dados de sinal válidos para análise.\")"
      ],
      "execution_count": null,
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 1800x1200 with 2 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        },
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "\n",
            "--- Prevalência de Componentes de Sinal em Trades Perdedores (Teste de Estresse) ---\n",
            "Total de Trades Perdedores Analisados: 6\n",
            "  killzone: 6 vezes (100.0%)\n",
            "  hammer: 4 vezes (66.7%)\n",
            "  sweep_low: 4 vezes (66.7%)\n",
            "  bear_fvg: 4 vezes (66.7%)\n",
            "  flow_bull: 4 vezes (66.7%)\n",
            "  shooting_star: 2 vezes (33.3%)\n",
            "  sweep_high: 2 vezes (33.3%)\n",
            "  flow_bear: 2 vezes (33.3%)\n",
            "  bull_fvg: 1 vezes (16.7%)\n",
            "  flip_bull: 1 vezes (16.7%)\n"
          ]
        }
      ]
    },
