    {
      "cell_type": "markdown",
      "metadata": {
        "id": "36860cae"
      },
      "source": [
        "### Creating `df_simulated_ohlcv` with High Volatility"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 261
        },
        "id": "ba22cd26",
        "outputId": "aad532bc-1353-49e0-97b2-291667b3656e"
      },
      "source": [
        "print(\"\\n--- Simulação de Dados de Alta Volatilidade para df_simulated_ohlcv ---\")\n",
        "\n",
        "# Fator de amplificação da volatilidade\n",
        "volatility_factor = 2.0\n",
        "\n",
        "df_simulated_high_volatility = df_btc_usd_new.copy()\n",
        "\n",
        "# Calcular os retornos diários (ou por barra)\n",
        "df_simulated_high_volatility['return'] = df_simulated_high_volatility['close'].pct_change()\n",
        "\n",
        "# Amplificar os retornos\n",
        "df_simulated_high_volatility['amplified_return'] = df_simulated_high_volatility['return'] * volatility_factor\n",
        "\n",
        "# Recalcular os preços de fechamento a partir dos retornos amplificados\n",
        "# O primeiro preço de fechamento é mantido, os demais são reconstruídos\n",
        "df_simulated_high_volatility['sim_close'] = df_simulated_high_volatility['close'].iloc[0] * (1 + df_simulated_high_volatility['amplified_return']).cumprod()\n",
        "\n",
        "# Ajustar Open, High, Low proporcionalmente à nova variação de Close\n",
        "# Para simplificar, ajustaremos a variação de cada barra. Isso pode ser mais sofisticado.\n",
        "for i in range(1, len(df_simulated_high_volatility)):\n",
        "    original_close_curr = df_btc_usd_new['close'].iloc[i]\n",
        "\n",
        "    # Aplicar um fator de escala para 'open', 'high', 'low' com base na amplificação do close.\n",
        "    # Basicamente, ajustamos a barra inteira pela mesma proporção que o close foi ajustado.\n",
        "    ratio_change = df_simulated_high_volatility['sim_close'].iloc[i] / original_close_curr if original_close_curr != 0 else 1.0\n",
        "\n",
        "    df_simulated_high_volatility.loc[i, 'sim_open'] = df_btc_usd_new['open'].iloc[i] * ratio_change\n",
        "    df_simulated_high_volatility.loc[i, 'sim_high'] = df_btc_usd_new['high'].iloc[i] * ratio_change\n",
        "    df_simulated_high_volatility.loc[i, 'sim_low'] = df_btc_usd_new['low'].iloc[i] * ratio_change\n",
        "\n",
        "# Corrigir o primeiro 'sim_open' para ser igual ao primeiro 'open' original\n",
        "df_simulated_high_volatility.loc[0, 'sim_open'] = df_btc_usd_new['open'].iloc[0]\n",
        "df_simulated_high_volatility.loc[0, 'sim_high'] = df_btc_usd_new['high'].iloc[0]\n",
        "df_simulated_high_volatility.loc[0, 'sim_low'] = df_btc_usd_new['low'].iloc[0]\n",
        "\n",
        "# Criar o DataFrame final com os dados simulados\n",
        "df_simulated_ohlcv = pd.DataFrame({\n",
        "    'timestamp': df_simulated_high_volatility['timestamp'],\n",
        "    'open': df_simulated_high_volatility['sim_open'],\n",
        "    'high': df_simulated_high_volatility['sim_high'],\n",
        "    'low': df_simulated_high_volatility['sim_low'],\n",
        "    'close': df_simulated_high_volatility['sim_close'],\n",
        "    'volume': df_simulated_high_volatility['volume'] # Mantemos o volume original ou podemos amplificá-lo também\n",
        "})\n",
        "\n",
        "# Remover a primeira linha que pode ter NaN nos 'sim_'\n",
        "df_simulated_ohlcv = df_simulated_ohlcv.dropna().reset_index(drop=True)\n",
        "\n",
        "display(df_simulated_ohlcv.head())\n",
        "print(f\"df_simulated_ohlcv created with {len(df_simulated_ohlcv)} rows.\")"
      ],
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "\n",
            "--- Simulação de Dados de Alta Volatilidade para df_simulated_ohlcv ---\n"
          ]
        },
