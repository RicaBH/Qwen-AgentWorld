      "source": [
        "import mplfinance as mpf\n",
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "print(\"\\n--- Gerando Gráfico de Desempenho para BTC/USD (Estratégia v6.2) ---\")\n",
        "\n",
        "try:\n",
        "    # Ensure df_btc_usd_new is indexed by datetime for mplfinance\n",
        "    df_plot = df_btc_usd_new.copy()\n",
        "    df_plot = df_plot.set_index(pd.DatetimeIndex(df_plot['timestamp']))\n",
        "\n",
        "    # Prepare market colors and style for mplfinance\n",
        "    mc = mpf.make_marketcolors(up='green', down='red', wick='inherit', edge='inherit', volume='in', ohlc='i')\n",
        "    s = mpf.make_mpf_style(marketcolors=mc, gridcolor='gray', gridstyle=':', y_on_right=False)\n",
        "\n",
        "    # Create subplots\n",
        "    fig = plt.figure(figsize=(18, 16))\n",
        "    gs = fig.add_gridspec(3, 1, height_ratios=[3, 1, 1])\n",
        "\n",
        "    ax_main = fig.add_subplot(gs[0, 0])\n",
        "    ax_volume = fig.add_subplot(gs[1, 0], sharex=ax_main)\n",
        "    ax_equity = fig.add_subplot(gs[2, 0], sharex=ax_main)\n",
        "\n",
        "    # Plot OHLCV and volume using mplfinance\n",
        "    mpf.plot(\n",
        "        df_plot,\n",
        "        type='candle',\n",
        "        ax=ax_main,\n",
        "        volume=ax_volume,\n",
        "        show_nontrading=False,\n",
        "        axtitle=f'{symbol_btc_usd} - OHLCV com Sinais de Trade (v6.2)',\n",
        "        xrotation=0,\n",
        "        style=s\n",
        "    )\n",
        "\n",
        "    # Plot signals manually on ax_main using the signals DataFrame from BacktestResult\n",
        "    signals_df_v62 = result_btc_usd_v62.signals\n",
        "    if signals_df_v62 is not None:\n",
        "        # Ensure signals_df_v62 index matches df_plot index\n",
        "        signals_df_v62.index = df_plot.index\n",
        "\n",
        "        # Buy Signals (LONG)\n",
        "        buy_signals_indices = signals_df_v62[signals_df_v62['signal_type'] == 'LONG'].index\n",
        "        if not buy_signals_indices.empty:\n",
        "            ax_main.scatter(\n",
        "                buy_signals_indices,\n",
        "                df_plot.loc[buy_signals_indices]['low'] * 0.99, # Position slightly below the low\n",
        "                marker='^',\n",
        "                color='green',\n",
        "                s=100,\n",
        "                zorder=5\n",
        "            )\n",
        "\n",
        "        # Sell Signals (SHORT)\n",
        "        sell_signals_indices = signals_df_v62[signals_df_v62['signal_type'] == 'SHORT'].index\n",
        "        if not sell_signals_indices.empty:\n",
        "            ax_main.scatter(\n",
        "                sell_signals_indices,\n",
        "                df_plot.loc[sell_signals_indices]['high'] * 1.01, # Position slightly above the high\n",
        "                marker='v',\n",
        "                color='red',\n",
        "                s=100,\n",
        "                zorder=5\n",
        "            )\n",
        "\n",
        "    # Plot equity curve on ax_equity\n",
        "    ax_equity.plot(result_btc_usd_v62.equity_curve, color='blue', label='Equity Curve')\n",
        "    ax_equity.set_title('Curva de Capital (Equity Curve)')\n",
        "    ax_equity.set_xlabel('Bar Index')\n",
        "    ax_equity.set_ylabel('Equity Multiplier')\n",
        "    ax_equity.grid(True)\n",
        "    ax_equity.legend()\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "except Exception as e:\n",
        "    print(f\"Ocorreu um erro ao gerar o gráfico para BTC/USD com a v6.2: {e}\")\n"
      ],
      "execution_count": null,
