      "source": [
        "# Exemplo: carregar dados da Kraken para 100 pares\n",
        "import ccxt\n",
        "import pandas as pd\n",
        "\n",
        "# Usar a instância da Kraken que já foi criada e carregada\n",
        "# kraken_exchange = ccxt.kraken() # Não é necessário criar novamente se já estiver no kernel\n",
        "\n",
        "# Certifique-se de que kraken_exchange esteja disponível no escopo global ou passe-o como argumento\n",
        "# Para este exemplo, assumimos que 'kraken_exchange' já está definido no kernel global.\n",
        "\n",
        "# Em vez de carregar todos os mercados novamente, podemos usar 'kraken_markets' que já carregamos\n",
        "# ou carregar novamente se preferir a consistência neste bloco.\n",
        "\n",
        "# Nota: O limite de 100 pares é apenas um exemplo. Você pode ajustar.\n",
        "symbols = [s for s in kraken_markets.keys() if '/USD' in s or '/USDT' in s or '/EUR' in s][:100]\n",
        "\n",
        "# Lista para armazenar todos os resultados do backtest\n",
        "all_results = []\n",
        "\n",
        "for sym in symbols:\n",
        "    try:\n",
        "        ohlcv = kraken_exchange.fetch_ohlcv(sym, '5m', limit=1000)\n",
        "        if ohlcv:\n",
        "            df = pd.DataFrame(ohlcv, columns=['timestamp','open','high','low','close','volume'])\n",
        "            df['timestamp'] = pd.to_datetime(df['timestamp'], unit='ms') # Converter para datetime para a função session_filter\n",
        "            result = run_backtest(df, params)\n",
        "            all_results.append((sym, result))\n",
        "            print(f\"Resultados para {sym}: Total Trades = {result.total_trades}, Win Rate = {result.win_rate:.2%}, Avg R:R = {result.avg_rr:.2f}\")\n",
        "        else:\n",
        "            print(f\"Nenhum dado OHLCV encontrado para {sym}\")\n",
        "    except ccxt.NetworkError as e:\n",
        "        print(f\"Erro de rede ao buscar dados para {sym}: {e}\")\n",
        "    except ccxt.ExchangeError as e:\n",
        "        print(f\"Erro da exchange ao buscar dados para {sym}: {e}\")\n",
        "    except Exception as e:\n",
        "        print(f\"Ocorreu um erro inesperado ao processar {sym}: {e}\")\n",
        "\n",
        "# Exibir um resumo dos resultados acumulados (opcional)\n",
        "print(\"\\n--- Resumo de Todos os Backtests ---\")\n",
        "if all_results:\n",
        "    for sym, res in all_results:\n",
        "        print(f\"{sym}: Trades={res.total_trades}, Win Rate={res.win_rate:.2%}, Avg R:R={res.avg_rr:.2f}\")\n",
        "else:\n",
        "    print(\"Nenhum backtest foi executado com sucesso.\")"
      ],
