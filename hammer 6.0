      "source": [
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Prepare data for PnL distribution plotting\n",
        "# We'll use the trades from the stress test result\n",
        "trades_data_for_plot = []\n",
        "\n",
        "# Define the list of active signal components to analyze\n",
        "active_signal_components_to_plot = [\n",
        "    'hammer', 'shooting_star', 'sweep_low', 'sweep_high', 'killzone',\n",
        "    'bull_fvg', 'bear_fvg', 'flip_bull', 'flip_bear', 'flow_bull', 'flow_bear'\n",
        "]\n",
        "\n",
        "if result_stress_test.signals is not None:\n",
        "    signals_df_stress = result_stress_test.signals.copy()\n",
        "\n",
        "    for trade in result_stress_test.trades:\n",
        "        entry_bar_idx = trade.entry_bar\n",
        "        # Ensure the index is valid for signals_df_stress\n",
        "        if entry_bar_idx < len(signals_df_stress):\n",
        "            signal_data = signals_df_stress.iloc[entry_bar_idx]\n",
        "\n",
        "            # For each trade, add an entry for every active signal component\n",
        "            for component in active_signal_components_to_plot:\n",
        "                if component in signal_data and isinstance(signal_data[component], (bool, np.bool_)) and signal_data[component]:\n",
        "                    trades_data_for_plot.append({\n",
        "                        'PnL_R': trade.pnl_r,\n",
        "                        'Active_Signal_Component': component\n",
        "                    })\n",
        "\n",
        "# Convert to DataFrame for easier plotting\n",
        "df_pnl_distribution_by_component = pd.DataFrame(trades_data_for_plot)\n",
        "\n",
        "if not df_pnl_distribution_by_component.empty:\n",
        "    plt.figure(figsize=(14, 8)) # Increased figure size for more components\n",
        "    sns.boxplot(x='Active_Signal_Component', y='PnL_R', data=df_pnl_distribution_by_component)\n",
        "    plt.title('Distribuição de PnL (R-múltiplos) por Componente de Sinal Ativo (Teste de Estresse)')\n",
        "    plt.xlabel('Componente de Sinal Ativo')\n",
        "    plt.ylabel('PnL (R-múltiplos)')\n",
        "    plt.xticks(rotation=45, ha='right') # Rotate x-axis labels for better readability\n",
        "    plt.grid(True, linestyle='--', alpha=0.7)\n",
        "    plt.tight_layout() # Adjust layout to prevent labels from overlapping\n",
        "    plt.show()\n",
        "else:\n",
        "    print(\"Nenhum trade encontrado para plotar a distribuição de PnL por componente de sinal ativo.\")"
      ],
      "execution_count": null,
      "outputs": [
        {
