      },
      "source": [
        "def is_bearish_shooting_star(df):\n",
        "    \"\"\"\n",
        "    Traduz a lógica Pine Script isBearishShootingStar para Python.\n",
        "    Determina se um candle é uma estrela cadente de baixa.\n",
        "    \"\"\"\n",
        "    # Certifique-se de que as colunas necessárias existam\n",
        "    required_columns = ['open', 'close', 'high', 'low']\n",
        "    for col in required_columns:\n",
        "        if col not in df.columns:\n",
        "            raise ValueError(f\"DataFrame must contain a '{col}' column.\")\n",
        "\n",
        "    body = np.abs(df['open'] - df['close'])\n",
        "    wick_low = np.minimum(df['open'], df['close']) - df['low']\n",
        "    wick_high = df['high'] - np.maximum(df['open'], df['close'])\n",
        "    total_range = df['high'] - df['low']\n",
        "\n",
        "    # Condições para ser uma estrela cadente de baixa\n",
        "    # totalRange > 0: o candle deve ter algum range\n",
        "    # body > 0: o candle deve ter um corpo (não ser um doji perfeito)\n",
        "    # wickHigh >= body * 2.0: a sombra superior deve ser pelo menos o dobro do corpo\n",
        "    # wickLow <= total_range * 0.33: a sombra inferior deve ser pequena (menos de 1/3 do range total)\n",
        "    is_shooting_star = (\n",
        "        (total_range > 0) &\n",
        "        (body > 0) &\n",
        "        (wick_high >= body * 2.0) &\n",
        "        (wick_low <= total_range * 0.33)\n",
        "    )\n",
        "    return is_shooting_star\n",
        "\n",
        "# Exemplo de como usar a função (após carregar seu DataFrame 'df')\n",
        "# df['is_shooting_star'] = is_bearish_shooting_star(df)\n",
        "# display(df[['open', 'high', 'low', 'close', 'is_shooting_star']].tail())\n"
      ],
      "execution_count": null,
      "outputs": []
    },
