    {
      "cell_type": "markdown",
      "metadata": {
        "id": "3e21b5e1"
      },
      "source": [
        "Neste código, `ccxt.kraken()` cria uma instância da exchange Kraken. Adicionei um bloco `try-except` para carregar os mercados e imprimir o número de mercados, o que serve como uma verificação básica de que a conexão foi bem-sucedida e que os dados podem ser acessados."
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "da0bbe66"
      },
      "source": [
        "### Definição da Função `run_backtest` e Parâmetros\n",
        "\n",
        "Antes de rodar a simulação, precisamos definir a função `run_backtest` e a variável `params` que serão usadas no loop principal. Abaixo estão as definições de placeholder para você começar."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "068c5a7b"
      },
      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "from dataclasses import dataclass, field\n",
        "from typing import List, Dict, Tuple, Optional\n",
        "from datetime import datetime, timedelta\n",
        "import warnings\n",
        "\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "\n",
        "@dataclass\n",
        "class Params:\n",
        "    \"\"\"Parâmetros idênticos ao Pine Script.\"\"\"\n",
        "\n",
        "    # Core\n",
        "    lookback_sweep: int = 20\n",
        "    cooldown_bars: int = 5\n",
        "    min_setup_score: int = 2\n",
        "    tp1_rr: float = 1.5  # Ajustado para 1 ATR\n",
        "    tp2_rr: float = 3.0  # Ajustado para 2 ATR\n",
        "\n",
        "    # New: Score weights\n",
        "    w_sweep: float = 1.0\n",
        "    w_killzone: float = 1.0\n",
        "    w_fvg: float = 1.0\n",
        "    w_flip: float = 1.0\n",
        "    w_flow: float = 1.0\n",
        "    use_hammer_filter: bool = True # New parameter for hammer filter\n",
        "    use_shooting_star_filter: bool = True # New parameter for shooting star filter\n",
        "\n",
        "    # Session\n",
        "    use_london: bool = False\n",
        "    use_ny: bool = False\n",
        "\n",
        "    # Volume & Flow\n",
        "    vol_ma_period: int = 20\n",
        "    rev_vol_mult: float = 1.5\n",
        "    use_volume_filter: bool = False\n",
        "\n",
        "    # Flip Detection\n",
        "    flip_lookback: int = 50\n",
        "    flip_tolerance: float = 0.001\n",
        "\n",
        "    # Risk Management\n",
        "    use_atr_stop: bool = True\n",
        "    atr_period: int = 14\n",
        "    atr_multiplier: float = 1.5\n",
        "    slippage_pct: float = 0.05\n",
        "\n",
        "    # Regime Detection\n",
        "    use_trend_filter: bool = False\n",
        "    trend_period: int = 50\n",
        "    trend_slope_min: float = 0.0\n",
        "\n",
        "    # Visual\n",
        "    show_dashboard: bool = True\n",
        "    show_zones: bool = True\n",
        "\n",
        "\n",
        "@dataclass\n",
        "class Trade:\n",
        "    \"\"\"Representa um trade individual.\"\"\"\n",
        "\n",
        "    entry_bar: int\n",
        "    entry_price: float\n",
        "    direction: int  # 1=long, -1=short\n",
        "    sl: float\n",
        "    tp1: float\n",
        "    tp2: float\n",
        "    score: int\n",
        "    exit_bar: int = 0\n",
        "    exit_price: float = 0.0\n",
        "    exit_type: str = \"\"\n",
        "    pnl_r: float = 0.0\n",
        "\n",
        "    # Para visualização\n",
        "    label: str = \"\"\n",
        "    color: str = \"\"\n",
        "\n",
        "\n",
        "@dataclass\n",
        "class BacktestResult:\n",
        "    \"\"\"Resultado completo de um backtest.\"\"\"\n",
        "\n",
        "    trades: List[Trade]\n",
        "    equity_curve: np.ndarray\n",
        "    params: dict\n",
        "\n",
        "    # Dados do gráfico para plotagem\n",
        "    signals: Optional[pd.DataFrame] = None\n",
        "\n",
        "    @property\n",
        "    def total_trades(self) -> int:\n",
        "        return len(self.trades)\n",
        "\n",
        "    @property\n",
        "    def wins(self) -> int:\n",
        "        return sum(1 for t in self.trades if t.pnl_r > 0)\n",
        "\n",
        "    @property\n",
        "    def losses(self) -> int:\n",
        "        return sum(1 for t in self.trades if t.pnl_r < 0)\n",
        "\n",
        "    @property\n",
        "    def win_rate(self) -> float:\n",
        "        return self.wins / max(self.total_trades, 1)\n",
        "\n",
        "    @property\n",
        "    def avg_rr(self) -> float:\n",
        "        if not self.trades:\n",
        "            return 0.0\n",
        "        return np.mean([t.pnl_r for t in self.trades])\n",
        "\n",
        "    @property\n",
        "    def profit_factor(self) -> float:\n",
        "        gross_profit = sum(t.pnl_r for t in self.trades if t.pnl_r > 0)\n",
        "        gross_loss = abs(sum(t.pnl_r for t in self.trades if t.pnl_r < 0))\n",
        "        return gross_profit / max(gross_loss, 0.001)\n",
        "\n",
        "    @property\n",
        "    def expectancy(self) -> float:\n",
        "        if not self.trades:\n",
        "            return 0.0\n",
        "        wins_r = [t.pnl_r for t in self.trades if t.pnl_r > 0]\n",
        "        losses_r = [t.pnl_r for t in self.trades if t.pnl_r < 0]\n",
        "        avg_win = np.mean(wins_r) if wins_r else 0\n",
        "        avg_loss = abs(np.mean(losses_r)) if losses_r else 0\n",
        "        wr = self.win_rate\n",
        "        return (wr * avg_win) - ((1 - wr) * avg_loss)\n",
        "\n",
        "    @property\n",
        "    def max_drawdown(self) -> float:\n",
        "        if len(self.equity_curve) < 2:\n",
        "            return 0.0\n",
        "        peak = np.maximum.accumulate(self.equity_curve)\n",
        "        dd = (peak - self.equity_curve) / np.where(peak > 0, peak, 1)\n",
        "        return float(np.max(dd))\n",
        "\n",
        "    @property\n",
        "    def sharpe_ratio(self) -> float:\n",
        "        if not self.trades:\n",
        "            return 0.0\n",
        "        returns = np.array([t.pnl_r for t in self.trades])\n",
        "        if np.std(returns) == 0:\n",
        "            return 0.0\n",
        "        return float(np.mean(returns) / np.std(returns) * np.sqrt(252))\n",
        "\n",
        "    def summary(self) -> str:\n",
        "        return (\n",
        "            f\"{'='*50}\\n\"\n",
        "            f\"  HAMMER MODEL PRO — BACKTEST REPORT\\n\"\n",
        "            f\"{'='*50}\\n\"\n",
        "            f\"  Total Trades    : {self.total_trades:>8,}\\n\"\n",
        "            f\"  Wins / Losses   : {self.wins:>5} / {self.losses}\\n\"\n",
        "            f\"  Win Rate        : {self.win_rate:>8.1%}\\n\"\n",
        "            f\"  Avg R:R         : {self.avg_rr:>8.3f}R\\n\"\n",
        "            f\"  Profit Factor   : {self.profit_factor:>8.2f}\\n\"\n",
        "            f\"  Expectancy      : {self.expectancy:>8.3f}R\\n\"\n",
        "            f\"  Sharpe Ratio    : {self.sharpe_ratio:>8.2f}\\n\"\n",
        "            f\"  Max Drawdown    : {self.max_drawdown:>8.1%}\\n\"\n",
        "            f\"{'='*50}\\n\"\n",
        "        )\n",
        "\n",
        "def rolling_sma(arr: np.ndarray, period: int) -> np.ndarray:\n",
        "    \"\"\"SMA simples — equivalente a ta.sma() do Pine.\"\"\"\n",
        "    result = np.full_like(arr, np.nan, dtype=float)\n",
        "    cs = np.cumsum(arr, dtype=float)\n",
        "    result[period - 1 :] = cs[period - 1 :] / period\n",
        "    result[period:] = (cs[period:] - cs[:-period]) / period\n",
        "    return result\n",
        "\n",
        "\n",
        "def rolling_min(arr: np.ndarray, period: int) -> np.ndarray:\n",
        "    \"\"\"Mínima rolling — equivalente a ta.lowest(low, N)[1].\"\"\"\n",
        "    n = len(arr)\n",
        "    result = np.full(n, np.nan)\n",
        "    for i in range(period, n):\n",
        "        result[i] = np.min(arr[i - period : i])  # Exclui barra atual\n",
        "    return result\n",
        "\n",
        "\n",
        "def rolling_max(arr: np.ndarray, period: int) -> np.ndarray:\n",
        "    \"\"\"Máxima rolling — equivalente a ta.highest(high, N)[1].\"\"\"\n",
        "    n = len(arr)\n",
        "    result = np.full(n, np.nan)\n",
        "    for i in range(period, n):\n",
        "        result[i] = np.max(arr[i - period : i])\n",
        "    return result\n",
        "\n",
        "\n",
        "def rolling_max_incl(arr: np.ndarray, period: int) -> np.ndarray:\n",
        "    \"\"\"Máxima rolling incluindo barra atual — ta.highest(close, 5).\"\"\"\n",
        "    n = len(arr)\n",
        "    result = np.full(n, np.nan)\n",
        "    for i in range(period - 1, n):\n",
        "        result[i] = np.max(arr[max(0, i - period + 1) : i + 1])\n",
        "    return result\n",
        "\n",
        "\n",
        "def rolling_min_incl(arr: np.ndarray, period: int) -> np.ndarray:\n",
        "    \"\"\"Mínima rolling incluindo barra atual — ta.lowest(close, 5).\"\"\"\n",
        "    n = len(arr)\n",
        "    result = np.full(n, np.nan)\n",
        "    for i in range(period - 1, n):\n",
        "        result[i] = np.min(arr[max(0, i - period + 1) : i + 1])\n",
        "    return result\n",
        "\n",
        "\n",
        "def calc_atr(high: np.ndarray, low: np.ndarray, close: np.ndarray, period: int) -> np.ndarray:\n",
        "    \"\"\"ATR — equivalente a ta.atr().\"\"\"\n",
        "    n = len(high)\n",
        "    tr = np.zeros(n)\n",
        "    tr[0] = high[0] - low[0]\n",
        "    for i in range(1, n):\n",
        "        tr[i] = max(\n",
        "            high[i] - low[i],\n",
        "            abs(high[i] - close[i - 1]),\n",
        "            abs(low[i] - close[i - 1]),\n",
        "        )\n",
        "    return rolling_sma(tr, period)\n",
        "\n",
        "def detect_hammer(o: np.ndarray, h: np.ndarray, l: np.ndarray, c: np.ndarray) -> np.ndarray:\n",
        "    \"\"\"\n",
        "    Bullish Hammer — equivalente a isBullishHammer().\n",
        "    Pavio inferior >= 2x corpo, pavio superior <= 33% do range.\n",
        "    \"\"\"\n",
        "    n = len(o)\n",
        "    result = np.zeros(n, dtype=bool)\n",
        "    for i in range(n):\n",
        "        body = abs(o[i] - c[i])\n",
        "        wick_low = min(o[i], c[i]) - l[i]\n",
        "        wick_high = h[i] - max(o[i], c[i])\n",
        "        total_range = h[i] - l[i]\n",
        "        if total_range > 0 and body > 0:\n",
        "            result[i] = wick_low >= body * 2.0 and wick_high <= total_range * 0.33\n",
        "    return result\n",
        "\n",
        "\n",
        "def detect_shooting_star(o: np.ndarray, h: np.ndarray, l: np.ndarray, c: np.ndarray) -> np.ndarray:\n",
        "    \"\"\"\n",
        "    Bearish Shooting Star — equivalente a isBearishShootingStar().\n",
        "    Pavio superior >= 2x corpo, pavio inferior <= 33% do range.\n",
        "    \"\"\"\n",
        "    n = len(o)\n",
        "    result = np.zeros(n, dtype=bool)\n",
        "    for i in range(n):\n",
        "        body = abs(o[i] - c[i])\n",
        "        wick_low = min(o[i], c[i]) - l[i]\n",
        "        wick_high = h[i] - max(o[i], c[i])\n",
        "        total_range = h[i] - l[i]\n",
        "        if total_range > 0 and body > 0:\n",
        "            result[i] = wick_high >= body * 2.0 and wick_low <= total_range * 0.33\n",
        "    return result\n",
        "\n",
        "def detect_sweep(\n",
        "    low: np.ndarray, high: np.ndarray, lookback: int\n",
        ") -> Tuple[np.ndarray, np.ndarray]:\n",
        "    \"\"\"\n",
        "    Sweep direcional — equivalente a isValidSweep().\n",
        "    sweepLow: low atual <= mínima anterior\n",
        "    sweepHigh: high atual >= máxima anterior\n",
        "    \"\"\"\n",
        "    prev_low = rolling_min(low, lookback)\n",
        "    prev_high = rolling_max(high, lookback)\n",
        "    sweep_low = low <= prev_low\n",
        "    sweep_high = high >= prev_high\n",
        "    return sweep_low, sweep_high\n",
        "\n",
        "def session_filter(\n",
        "    timestamps: np.ndarray, use_london: bool, use_ny: bool\n",
        ") -> np.ndarray:\n",
        "    \"\"\"\n",
        "    Filtro de sessão — equivalente a isInSession().\n",
        "    Sem filtro ativado = todas as sessões válidas.\n",
        "    \"\"\"\n",
        "    n = len(timestamps)\n",
        "    if not use_london and not use_ny:\n",
        "        return np.ones(n, dtype=bool)\n",
        "\n",
        "    result = np.zeros(n, dtype=bool)\n",
        "    for i in range(n):\n",
        "        if isinstance(timestamps[i], (pd.Timestamp, datetime)):\n",
        "            h = timestamps[i].hour\n",
        "            m = timestamps[i].minute\n",
        "        else:\n",
        "            dt = pd.Timestamp(timestamps[i], unit=\"ms\")\n",
        "            h = dt.hour\n",
        "            m = dt.minute\n",
        "        t = h * 100 + m\n",
        "        london = use_london and 300 <= t <= 1100\n",
        "        ny = use_ny and 800 <= t <= 1600\n",
        "        result[i] = london or ny\n",
        "    return result\n",
        "\n",
        "def detect_bullish_fvg(h: np.ndarray, l: np.ndarray) -> np.ndarray:\n",
        "    \"\"\"Bullish FVG — equivalente a isBullishFVG().\"\"\"\n",
        "    n = len(h)\n",
        "    result = np.zeros(n, dtype=bool)\n",
        "    for i in range(2, n):\n",
        "        result[i] = l[i] > h[i - 2]\n",
        "    return result\n",
        "\n",
        "def detect_bearish_fvg(h: np.ndarray, l: np.ndarray) -> np.ndarray:\n",
        "    \"\"\"Bearish FVG — equivalente a isBearishFVG().\"\"\"\n",
        "    n = len(h)\n",
        "    result = np.zeros(n, dtype=bool)\n",
        "    for i in range(2, n):\n",
        "        result[i] = h[i] < l[i - 2]\n",
        "    return result\n",
        "\n",
        "def detect_flip_bull(\n",
        "    close: np.ndarray, high: np.ndarray, low: np.ndarray,\n",
        "    resistance: np.ndarray, tolerance: float,\n",
        ") -> np.ndarray:\n",
        "    \"\"\"\n",
        "    Flip bullish — equivalente a isFlipBullish().\n",
        "    Resistência rompida → testada como suporte.\n",
        "    \"\"\"\n",
        "    n = len(close)\n",
        "    result = np.zeros(n, dtype=bool)\n",
        "    highest_5 = rolling_max_incl(close, 5)\n",
        "    for i in range(n):\n",
        "        if np.isnan(resistance[i]) or np.isnan(highest_5[i]):\n",
        "            continue\n",
        "        brk = highest_5[i] > resistance[i]\n",
        "        tst = low[i] <= resistance[i] * (1 + tolerance) and close[i] > resistance[i]\n",
        "        result[i] = brk and tst\n",
        "    return result\n",
        "\n",
        "\n",
        "def detect_flip_bear(\n",
        "    close: np.ndarray, high: np.ndarray, low: np.ndarray,\n",
        "    support: np.ndarray, tolerance: float,\n",
        ") -> np.ndarray:\n",
        "    \"\"\"\n",
        "    Flip bearish — equivalente a isFlipBearish().\n",
        "    Suporte rompido → testado como resistência.\n",
        "    \"\"\"\n",
        "    n = len(close)\n",
        "    result = np.zeros(n, dtype=bool)\n",
        "    lowest_5 = rolling_min_incl(close, 5)\n",
        "    for i in range(n):\n",
        "        if np.isnan(support[i]) or np.isnan(lowest_5[i]):\n",
        "            continue\n",
        "        brk = lowest_5[i] < support[i]\n",
        "        tst = high[i] >= support[i] * (1 - tolerance) and close[i] < support[i]\n",
        "        result[i] = brk and tst\n",
        "    return result\n",
        "\n",
        "\n",
        "def detect_flow_bullish(\n",
        "    o: np.ndarray, h: np.ndarray, l: np.ndarray, c: np.ndarray,\n",
        "    volume: np.ndarray, vol_ma: np.ndarray,\n",
        "    hammer: np.ndarray, rev_vol_mult: float, use_vol_filter: bool,\n",
        ") -> np.ndarray:\n",
        "    \"\"\"\n",
        "    Flow bullish — equivalente a isFlowBullish().\n",
        "    Engulfing bullish + hammer, com filtro de volume opcional.\n",
        "    \"\"\"\n",
        "    n = len(o)\n",
        "    result = np.zeros(n, dtype=bool)\n",
        "    for i in range(1, n):\n",
        "        ok_vol = not use_vol_filter or volume[i] > vol_ma[i] * rev_vol_mult\n",
        "        if not ok_vol:\n",
        "            continue\n",
        "        # Engulfing bullish\n",
        "        prev_bear = c[i - 1] < o[i - 1]\n",
        "        curr_bull = c[i] > o[i]\n",
        "        engulf = prev_bear and curr_bull and c[i] >= o[i - 1] and o[i] <= c[i - 1]\n",
        "        result[i] = hammer[i] or engulf\n",
        "    return result\n",
        "\n",
        "\n",
        "def detect_flow_bearish(\n",
        "    o: np.ndarray, h: np.ndarray, l: np.ndarray, c: np.ndarray,\n",
        "    volume: np.ndarray, vol_ma: np.ndarray,\n",
        "    shooting_star: np.ndarray, rev_vol_mult: float, use_vol_filter: bool,\n",
        ") -> np.ndarray:\n",
        "    \"\"\"\n",
        "    Flow bearish — equivalente a isFlowBearish().\n",
        "    Engulfing bearish + shooting star, com filtro de volume opcional.\n",
        "    \"\"\"\n",
        "    n = len(o)\n",
        "    result = np.zeros(n, dtype=bool)\n",
        "    for i in range(1, n):\n",
        "        ok_vol = not use_vol_filter or volume[i] > vol_ma[i] * rev_vol_mult\n",
        "        if not ok_vol:\n",
        "            continue\n",
        "        # Engulfing bearish\n",
        "        prev_bull = c[i - 1] > o[i - 1]\n",
        "        curr_bear = c[i] < o[i]\n",
        "        engulf = prev_bull and curr_bear and c[i] <= o[i - 1] and o[i] >= c[i - 1]\n",
        "        result[i] = shooting_star[i] or engulf\n",
        "    return result\n",
        "\n",
        "\n",
        "def calc_long_score(swp, kz, fvg, flip, flow, params: Params):\n",
        "    \"\"\"Score long — equivalente a calcLongScore().\"\"\"\n",
        "    return (\n",
        "        swp.astype(int) * params.w_sweep\n",
        "        + kz.astype(int) * params.w_killzone\n",
        "        + fvg.astype(int) * params.w_fvg\n",
        "        + flip.astype(int) * params.w_flip\n",
        "        + flow.astype(int) * params.w_flow\n",
        "    )\n",
        "\n",
        "\n",
        "def calc_short_score(swp, kz, fvg, flip, flow, params: Params):\n",
        "    \"\"\"Score short — equivalente a calcShortScore().\"\"\"\n",
        "    return (\n",
        "        swp.astype(int) * params.w_sweep\n",
        "        + kz.astype(int) * params.w_killzone\n",
        "        + fvg.astype(int) * params.w_fvg\n",
        "        + flip.astype(int) * params.w_flip\n",
        "        + flow.astype(int) * params.w_flow\n",
        "    )\n",
        "\n",
        "def calc_levels(\n",
        "    entry: float, is_long: bool,\n",
        "    atr_val: float, bar_range: float,\n",
        "    params: Params,\n",
        ") -> Tuple[float, float, float]:\n",
        "    \"\"\"\n",
        "    Calcula SL, TP1, TP2 — equivalente a calcLevels().\n",
        "    \"\"\"\n",
        "    if params.use_atr_stop:\n",
        "        r = atr_val * params.atr_multiplier\n",
        "    else:\n",
        "        r = bar_range * 0.2\n",
        "\n",
        "    if is_long:\n",
        "        sl = entry - r\n",
        "        tp1 = entry + r * params.tp1_rr\n",
        "        tp2 = entry + r * params.tp2_rr\n",
        "    else:\n",
        "        sl = entry + r\n",
        "        tp1 = entry - r * params.tp1_rr\n",
        "        tp2 = entry - r * params.tp2_rr\n",
        "\n",
        "    return sl, tp1, tp2\n",
        "\n",
        "def run_backtest(df: pd.DataFrame, params: Params) -> BacktestResult:\n",
        "    \"\"\"\n",
        "    Executa backtest completo — equivalente à lógica principal do Pine Script.\n",
        "\n",
        "    DataFrame esperado: columns = [timestamp, open, high, low, close, volume]\n",
        "    (timestamp pode ser datetime ou epoch ms)\n",
        "    \"\"\"\n",
        "    # Extrair arrays\n",
        "    o = df[\"open\"].values.astype(float)\n",
        "    h = df[\"high\"].values.astype(float)\n",
        "    l = df[\"low\"].values.astype(float)\n",
        "    c = df[\"close\"].values.astype(float)\n",
        "    v = df[\"volume\"].values.astype(float)\n",
        "    ts = df[\"timestamp\"].values if \"timestamp\" in df.columns else df.index.values\n",
        "    n = len(df)\n",
        "\n",
        "    # ── Indicadores pré-calculados ──\n",
        "    vol_ma = rolling_sma(v, params.vol_ma_period)\n",
        "    atr = calc_atr(h, l, c, params.atr_period)\n",
        "    trend_sma = rolling_sma(c, params.trend_period)\n",
        "\n",
        "    # Trend slope\n",
        "    trend_slope = np.zeros(n)\n",
        "    shift = params.trend_period\n",
        "    for i in range(shift, n):\n",
        "        if not np.isnan(trend_sma[i]) and not np.isnan(trend_sma[i - shift]):\n",
        "            denom = trend_sma[i - shift]\n",
        "            if denom != 0:\n",
        "                trend_slope[i] = (trend_sma[i] - denom) / denom * 100\n",
        "\n",
        "    # Support / Resistance\n",
        "    resistance = rolling_max(h, params.flip_lookback)\n",
        "    support = rolling_min(l, params.flip_lookback)\n",
        "\n",
        "    # ── Patterns ──\n",
        "    hammer = detect_hammer(o, h, l, c)\n",
        "    shooting_star = detect_shooting_star(o, h, l, c)\n",
        "\n",
        "    # Apply hammer/shooting_star filters based on parameters\n",
        "    hammer_eff = hammer if params.use_hammer_filter else np.zeros_like(hammer, dtype=bool)\n",
        "    shooting_star_eff = shooting_star if params.use_shooting_star_filter else np.zeros_like(shooting_star, dtype=bool)\n",
        "\n",
        "    # ── Sweep ──\n",
        "    sweep_low, sweep_high = detect_sweep(l, h, params.lookback_sweep)\n",
        "\n",
        "    # ── Session ──\n",
        "    killzone = session_filter(ts, params.use_london, params.use_ny)\n",
        "\n",
        "    # ── FVG ──\n",
        "    bull_fvg = detect_bullish_fvg(h, l)\n",
        "    bear_fvg = detect_bearish_fvg(h, l)\n",
        "\n",
        "    # ── Flip ──\n",
        "    flip_bull = detect_flip_bull(c, h, l, resistance, params.flip_tolerance)\n",
        "    flip_bear = detect_flip_bear(c, h, l, support, params.flip_tolerance)\n",
        "\n",
        "    # ── Flow ──\n",
        "    flow_bull = detect_flow_bullish(\n",
        "        o, h, l, c, v, vol_ma, hammer, params.rev_vol_mult, params.use_volume_filter\n",
        "    )\n",
        "    flow_bear = detect_flow_bearish(\n",
        "        o, h, l, c, v, vol_ma, shooting_star, params.rev_vol_mult, params.use_volume_filter\n",
        "    )\n",
        "\n",
        "    # ── Trend ──\n",
        "    trend_up = ~params.use_trend_filter | (trend_slope > params.trend_slope_min)\n",
        "    trend_down = ~params.use_trend_filter | (trend_slope < -params.trend_slope_min)\n",
        "\n",
        "    # ── Scoring direcional ──\n",
        "    long_score = calc_long_score(sweep_low, killzone, bull_fvg, flip_bull, flow_bull, params)\n",
        "    short_score = calc_short_score(sweep_high, killzone, bear_fvg, flip_bear, flow_bear, params)\n",
        "\n",
        "    # ── Condições de entrada ──\n",
        "    long_cond = (\n",
        "        (hammer_eff | flip_bull | flow_bull | bull_fvg) # Use filtered hammer\n",
        "        & sweep_low\n",
        "        & trend_up\n",
        "        & (long_score >= params.min_setup_score)\n",
        "    )\n",
        "    short_cond = (\n",
        "        (shooting_star_eff | flip_bear | flow_bear | bear_fvg) # Use filtered shooting_star\n",
        "        & sweep_high\n",
        "        & trend_down\n",
        "        & (short_score >= params.min_setup_score)\n",
        "    )\n",
        "\n",
        "    # ── Simulação de trades ──\n",
        "    trades: List[Trade] = []\n",
        "    in_trade = False\n",
        "    last_signal_bar = -params.cooldown_bars\n",
        "    current: Optional[Trade] = None\n",
        "    equity = 1.0\n",
        "    equity_curve = [1.0]\n",
        "    risk_pct = 0.02  # 2% do equity por trade\n",
        "\n",
        "    # Arrays para sinais (para visualização)\n",
        "    signal_type = np.full(n, \"\", dtype=object)\n",
        "    signal_score = np.zeros(n, dtype=int)\n",
        "\n",
        "    for i in range(2, n):\n",
        "        # ── Gestão de trade aberto ──\n",
        "        if in_trade and current is not None:\n",
        "            t = current\n",
        "            if t.direction == 1:  # Long\n",
        "                if l[i] <= t.sl:\n",
        "                    t.exit_bar = i\n",
        "                    t.exit_price = t.sl\n",
        "                    t.exit_type = \"SL\"\n",
        "                    t.pnl_r = -1.0\n",
        "                    equity *= 1 + (t.pnl_r * risk_pct)\n",
        "                    in_trade = False\n",
        "                    trades.append(t)\n",
        "                elif h[i] >= t.tp2:\n",
        "                    t.exit_bar = i\n",
        "                    t.exit_price = t.tp2\n",
        "                    t.exit_type = \"TP2\"\n",
        "                    t.pnl_r = params.tp2_rr\n",
        "                    equity *= 1 + (t.pnl_r * risk_pct)\n",
        "                    in_trade = False\n",
        "                    trades.append(t)\n",
        "                elif h[i] >= t.tp1:\n",
        "                    t.sl = t.entry_price  # Breakeven\n",
        "\n",
        "            else:  # Short\n",
        "                if h[i] >= t.sl:\n",
        "                    t.exit_bar = i\n",
        "                    t.exit_price = t.sl\n",
        "                    t.exit_type = \"SL\"\n",
        "                    t.pnl_r = -1.0\n",
        "                    equity *= 1 + (t.pnl_r * risk_pct)\n",
        "                    in_trade = False\n",
        "                    trades.append(t)\n",
        "                elif l[i] <= t.tp2:\n",
        "                    t.exit_bar = i\n",
        "                    t.exit_price = t.tp2\n",
        "                    t.exit_type = \"TP2\"\n",
        "                    t.pnl_r = params.tp2_rr\n",
        "                    equity *= 1 + (t.pnl_r * risk_pct)\n",
        "                    in_trade = False\n",
        "                    trades.append(t)\n",
        "                elif l[i] <= t.tp1:\n",
        "                    t.sl = t.entry_price\n",
        "\n",
        "        equity_curve.append(equity)\n",
        "\n",
        "        # ── Cooldown adaptativo ──\n",
        "        atr_val = atr[i] if not np.isnan(atr[i]) else (h[i] - l[i])\n",
        "        if c[i] * 0.001 > 0:\n",
        "            raw_cooldown = int(atr_val / (c[i] * 0.001))\n",
        "        else:\n",
        "            raw_cooldown = params.cooldown_bars\n",
        "        adaptive_cooldown = max(params.cooldown_bars, raw_cooldown)\n",
        "\n",
        "        # ── Entrada ──\n",
        "        if not in_trade and i >= last_signal_bar + adaptive_cooldown:\n",
        "            bar_range = h[i] - l[i]\n",
        "            risk_dist = atr_val * params.atr_multiplier if params.use_atr_stop else bar_range * 0.2\n",
        "\n",
        "            if risk_dist <= 0:\n",
        "                continue\n",
        "\n",
        "            if long_cond[i]:\n",
        "                entry_p = c[i] + bar_range * params.slippage_pct\n",
        "                sl_p, tp1_p, tp2_p = calc_levels(entry_p, True, atr_val, bar_range, params)\n",
        "                current = Trade(\n",
        "                    entry_bar=i,\n",
        "                    entry_price=entry_p,\n",
        "                    direction=1,\n",
        "                    sl=sl_p,\n",
        "                    tp1=tp1_p,\n",
        "                    tp2=tp2_p,\n",
        "                    score=int(long_score[i]),\n",
        "                    label=f\"LONG #{len(trades)+1}\",\n",
        "                    color=\"green\",\n",
        "                )\n",
        "                in_trade = True\n",
        "                last_signal_bar = i\n",
        "                signal_type[i] = \"LONG\"\n",
        "                signal_score[i] = int(long_score[i])\n",
        "\n",
        "            elif short_cond[i]:\n",
        "                entry_p = c[i] - bar_range * params.slippage_pct\n",
        "                sl_p, tp1_p, tp2_p = calc_levels(entry_p, False, atr_val, bar_range, params)\n",
        "                current = Trade(\n",
        "                    entry_bar=i,\n",
        "                    entry_price=entry_p,\n",
        "                    direction=-1,\n",
        "                    sl=sl_p,\n",
        "                    tp1=tp1_p,\n",
        "                    tp2=tp2_p,\n",
        "                    score=int(short_score[i]),\n",
        "                    label=f\"SHORT #{len(trades)+1}\",\n",
        "                    color=\"red\",\n",
        "                )\n",
        "                in_trade = True\n",
        "                last_signal_bar = i\n",
        "                signal_type[i] = \"SHORT\"\n",
        "                signal_score[i] = int(short_score[i])\n",
        "\n",
        "    # Fechar trade pendente no final\n",
        "    if in_trade and current is not None:\n",
        "        current.exit_bar = n - 1\n",
        "        current.exit_price = c[-1]\n",
        "        current.pnl_r = 0.0 # No PnL for unresolved trade at end\n",
        "        current.exit_type = \"EOF\"\n",
        "        trades.append(current)\n",
        "\n",
        "    # DataFrame de sinais para visualização\n",
        "    signals_df = pd.DataFrame(\n",
        "        {\n",
        "            \"hammer\": hammer,\n",
        "            \"shooting_star\": shooting_star,\n",
        "            \"sweep_low\": sweep_low,\n",
        "            \"sweep_high\": sweep_high,\n",
        "            \"killzone\": killzone,\n",
        "            \"bull_fvg\": bull_fvg,\n",
        "            \"bear_fvg\": bear_fvg,\n",
        "            \"flip_bull\": flip_bull,\n",
        "            \"flip_bear\": flip_bear,\n",
        "            \"flow_bull\": flow_bull,\n",
        "            \"flow_bear\": flow_bear,\n",
        "            \"long_score\": long_score,\n",
        "            \"short_score\": short_score,\n",
        "            \"signal_type\": signal_type,\n",
        "            \"signal_score\": signal_score,\n",
        "            \"support\": support,\n",
        "            \"resistance\": resistance,\n",
        "            \"atr\": atr,\n",
        "            \"vol_ma\": vol_ma,\n",
        "        }\n",
        "    )\n",
        "\n",
        "    return BacktestResult(\n",
        "        trades=trades,\n",
        "        equity_curve=np.array(equity_curve),\n",
        "        params=vars(params),\n",
        "        signals=signals_df,\n",
        "    )"
      ],
      "execution_count": null,
      "outputs": []
    },
