      "source": [
        "# Importar a biblioteca ccxt e pandas\n",
        "import ccxt\n",
        "import pandas as pd\n",
        "\n",
        "# Instanciar a exchange Kraken\n",
        "kraken_exchange = ccxt.kraken()\n",
        "\n",
        "# Opcionalmente, você pode carregar os mercados para verificar se está funcionando\n",
        "try:\n",
        "    kraken_markets = kraken_exchange.load_markets()\n",
        "    print(f\"Mercados carregados da Kraken: {len(kraken_markets)}\")\n",
        "except ccxt.NetworkError as e:\n",
        "    print(f\"Erro de rede ao conectar à Kraken: {e}\")\n",
        "except ccxt.ExchangeError as e:\n",
        "    print(f\"Erro da exchange Kraken: {e}\")\n",
        "except Exception as e:\n",
        "    print(f\"Ocorreu um erro inesperado ao inicializar a Kraken: {e}\")"
      ],
