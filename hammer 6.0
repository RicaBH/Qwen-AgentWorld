      "source": [
        "import numpy as np\n",
        "\n",
        "def is_bullish_hammer(df):\n",
        "    \"\"\"\n",
        "    Traduz a lógica Pine Script isBullishHammer para Python.\n",
        "    Determina se um candle é um martelo de alta.\n",
        "    \"\"\"\n",
        "    # Certifique-se de que as colunas necessárias existam\n",
        "    required_columns = ['open', 'close', 'high', 'low']\n",
        "    for col in required_columns:\n",
        "        if col not in df.columns:\n",
        "            raise ValueError(f\"DataFrame must contain a '{col}' column.\")\n",
        "\n",
        "    body = np.abs(df['open'] - df['close'])\n",
        "    wick_low = np.minimum(df['open'], df['close']) - df['low']\n",
        "    wick_high = df['high'] - np.maximum(df['open'], df['close'])\n",
        "    total_range = df['high'] - df['low']\n",
        "\n",
        "    # Condições para ser um martelo de alta\n",
        "    # totalRange > 0: o candle deve ter algum range\n",
        "    # body > 0: o candle deve ter um corpo (não ser um doji perfeito)\n",
        "    # wickLow >= body * 2.0: a sombra inferior deve ser pelo menos o dobro do corpo\n",
        "    # wickHigh <= totalRange * 0.33: a sombra superior deve ser pequena (menos de 1/3 do range total)\n",
        "    is_hammer = (\n",
        "        (total_range > 0) &\n",
        "        (body > 0) &\n",
        "        (wick_low >= body * 2.0) &\n",
        "        (wick_high <= total_range * 0.33)\n",
        "    )\n",
        "    return is_hammer\n",
        "\n",
        "# Exemplo de como usar a função com seu DataFrame 'df'\n",
        "# Certifique-se de que 'df' esteja disponível no ambiente\n",
        "# Se 'df' ainda não foi carregado ou é um DataFrame diferente, substitua 'df' pelo seu DataFrame\n",
        "\n",
        "# # Para testar, crie um DataFrame de exemplo:\n",
        "# data = {\n",
        "#     'open': [10, 10, 10, 10, 10],\n",
        "#     'high': [12, 11, 13, 10.5, 12],\n",
        "#     'low': [9, 8, 9.5, 9.5, 7],\n",
        "#     'close': [10.8, 10.5, 10.2, 9.8, 11]\n",
        "# }\n",
        "# df_test = pd.DataFrame(data)\n",
        "\n",
        "# # Adicione a coluna 'is_hammer' ao DataFrame\n",
        "# df['is_hammer'] = is_bullish_hammer(df)\n",
        "# display(df[['open', 'high', 'low', 'close', 'is_hammer']].tail())\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
