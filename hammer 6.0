        "print(\"\\n--- Reexecutando Backtest para BTC/USD com Novos Parâmetros ---\")\n",
        "\n",
        "symbol_btc_usd = 'BTC/USD'\n",
        "\n",
        "try:\n",
        "    # Fetch OHLCV data for BTC/USD (assuming it's the same data as before or re-fetching for freshness)\n",
        "    ohlcv_btc_usd = kraken_exchange.fetch_ohlcv(symbol_btc_usd, '5m', limit=1000)\n",
        "\n",
        "    if ohlcv_btc_usd:\n",
        "        df_btc_usd = pd.DataFrame(ohlcv_btc_usd, columns=['timestamp', 'open', 'high', 'low', 'close', 'volume'])\n",
        "        df_btc_usd['timestamp'] = pd.to_datetime(df_btc_usd['timestamp'], unit='ms')\n",
        "        df_btc_usd = df_btc_usd.set_index('timestamp') # Set timestamp as index for consistency\n",
        "\n",
        "        # Run backtest for BTC/USD with the updated params\n",
        "        result_btc_usd_updated = run_backtest(df_btc_usd, params)\n",
        "\n",
        "        print(f\"Resultados para {symbol_btc_usd} (Parâmetros Atualizados):\")\n",
        "        print(f\"  Total Trades = {result_btc_usd_updated.total_trades}\")\n",
        "        print(f\"  Win Rate = {result_btc_usd_updated.win_rate:.2%}\")\n",
        "        print(f\"  Avg R:R = {result_btc_usd_updated.avg_rr:.2f}\")\n",
        "        print(result_btc_usd_updated.summary()) # Print the full summary\n",
        "\n",
        "    else:\n",
        "        print(f\"Nenhum dado OHLCV encontrado para {symbol_btc_usd}\")\n",
