        "outputId": "cd752f7b-6883-4912-abdc-e4b05e80dbe1"
      },
      "source": [
        "# Calcular métricas agregadas\n",
        "total_trades_all = 0\n",
        "total_wins_all = 0\n",
        "total_losses_all = 0\n",
        "sum_rr_all = 0.0\n",
        "\n",
        "for sym, res in all_results:\n",
        "    total_trades_all += res.total_trades\n",
        "    total_wins_all += res.wins\n",
        "    total_losses_all += res.losses\n",
        "    sum_rr_all += res.avg_rr * res.total_trades if res.total_trades > 0 else 0\n",
        "\n",
        "overall_win_rate = total_wins_all / total_trades_all if total_trades_all > 0 else 0.0\n",
        "overall_avg_rr = sum_rr_all / total_trades_all if total_trades_all > 0 else 0.0\n",
        "\n",
        "print(\"\\n--- Métricas Agregadas do Backtest ---\")\n",
        "print(f\"Total de Pares Testados: {len(all_results)}\")\n",
        "print(f\"Total de Trades Realizados: {total_trades_all}\")\n",
        "print(f\"Total de Vitórias: {total_wins_all}\")\n",
        "print(f\"Total de Perdas: {total_losses_all}\")\n",
        "print(f\"Taxa de Vitória Geral: {overall_win_rate:.2%}\")\n",
        "print(f\"R:R Médio Geral: {overall_avg_rr:.2f}\")\n",
        "\n",
        "# Identificar os 5 melhores e 5 piores pares por R:R médio (apenas para pares com trades)\n",
        "successful_results = [(sym, res) for sym, res in all_results if res.total_trades > 0]\n",
        "\n",
        "if successful_results:\n",
        "    # Ordenar por R:R médio (decrescente para os melhores)\n",
        "    successful_results.sort(key=lambda x: x[1].avg_rr, reverse=True)\n",
        "\n",
        "    print(\"\\n--- Top 5 Pares por R:R Médio ---\")\n",
        "    for sym, res in successful_results[:5]:\n",
        "        print(f\"{sym}: Trades={res.total_trades}, Win Rate={res.win_rate:.2%}, Avg R:R={res.avg_rr:.2f}\")\n",
        "\n",
        "    print(\"\\n--- Piores 5 Pares por R:R Médio ---\")\n",
        "    for sym, res in successful_results[-5:]:\n",
        "        print(f\"{sym}: Trades={res.total_trades}, Win Rate={res.win_rate:.2%}, Avg R:R={res.avg_rr:.2f}\")\n",
        "else:\n",
        "    print(\"Nenhum par teve trades suficientes para análise de Top/Piores performers.\")"
      ],
      "execution_count": null,
