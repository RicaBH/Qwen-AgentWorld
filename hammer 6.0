    {
      "cell_type": "markdown",
      "metadata": {
        "id": "78fceedc"
      },
      "source": [
        "## Análise de Impacto Individual dos Pesos no Profit Factor (BTC/USD)\n",
        "\n",
        "Esta seção explora como a alteração de cada peso de score afeta o Fator de Lucro do backtest para o par BTC/USD. Cada peso será testado individualmente com valores de 0.5 e 2.0, enquanto os outros pesos permanecem em seu valor padrão de 1.0."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 228
        },
        "id": "439ddd9a",
        "outputId": "408bbd69-2df2-43b6-d8fc-c378a0be6456"
      },
      "source": [
        "import pandas as pd\n",
        "\n",
        "# Baseline Profit Factor (all weights = 1.0), obtained from result_btc_usd_v62 in a previous cell\n",
        "baseline_profit_factor = result_btc_usd_v62.profit_factor\n",
        "\n",
        "results_weight_impact = []\n",
        "results_weight_impact.append({\n",
        "    'Peso': 'Todos (Padrão)',\n",
        "    'Valor do Peso': '1.0 (baseline)',\n",
        "    'Profit Factor': baseline_profit_factor\n",
        "})\n",
        "\n",
        "weights_to_test = {\n",
        "    'w_sweep': [0.5, 2.0],\n",
        "    'w_killzone': [0.5, 2.0],\n",
        "    'w_fvg': [0.5, 2.0],\n",
        "    'w_flip': [0.5, 2.0],\n",
        "    'w_flow': [0.5, 2.0],\n",
        "}\n",
        "\n",
        "print(\"\\n--- Analisando Impacto Individual dos Pesos no Profit Factor (BTC/USD) ---\")\n",
        "\n",
        "for weight_name, test_values in weights_to_test.items():\n",
        "    for value in test_values:\n",
        "        print(f\"Testando {weight_name} = {value}...\")\n",
        "        temp_params = Params() # Começar com os parâmetros padrão (todos os pesos em 1.0)\n",
        "        setattr(temp_params, weight_name, value) # Definir apenas o peso atual\n",
        "\n",
        "        try:\n",
        "            # Re-executar o backtest com os parâmetros modificados\n",
        "            result_temp = run_backtest(df_btc_usd_new, temp_params)\n",
        "            results_weight_impact.append({\n",
        "                'Peso': weight_name,\n",
        "                'Valor do Peso': value,\n",
        "                'Profit Factor': result_temp.profit_factor\n",
        "            })\n",
        "            print(f\"  {weight_name} = {value}: Profit Factor = {result_temp.profit_factor:.2f}\")\n",
        "        except Exception as e:\n",
        "            print(f\"Ocorreu um erro ao testar {weight_name} = {value}: {e}\")\n",
        "            results_weight_impact.append({\n",
        "                'Peso': weight_name,\n",
        "                'Valor do Peso': value,\n",
        "                'Profit Factor': 'Erro'\n",
        "            })\n",
        "\n",
        "# Criar DataFrame para a tabela comparativa\n",
        "df_weight_impact = pd.DataFrame(results_weight_impact)\n",
        "df_weight_impact_sorted = df_weight_impact.sort_values(by='Profit Factor', ascending=False)\n",
        "\n",
        "print(\"\\n--- Tabela Comparativa de Impacto dos Pesos ---\")\n",
        "display(df_weight_impact_sorted)"
      ],
      "execution_count": null,
      "outputs": [
        {
          "output_type": "error",
          "ename": "NameError",
          "evalue": "name 'result_btc_usd_v62' is not defined",
          "traceback": [
