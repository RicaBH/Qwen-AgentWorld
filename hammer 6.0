      "source": [
        "import mplfinance as mpf\n",
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd\n",
        "import numpy as np # Adicionado para np.nan\n",
        "\n",
        "# Encontrar o par com o melhor R:R médio\n",
        "if successful_results:\n",
        "    best_performing_symbol, best_result = successful_results[0]\n",
        "    print(f\"\\nAnalisando o par com melhor desempenho: {best_performing_symbol}\")\n",
        "    print(f\"  Trades: {best_result.total_trades}, Win Rate: {best_result.win_rate:.2%}, Avg R:R: {best_result.avg_rr:.2f}\\n\")\n",
        "\n",
        "    # Re-fetch the OHLCV data for the best performing symbol\n",
        "    try:\n",
        "        ohlcv_best_sym = kraken_exchange.fetch_ohlcv(best_performing_symbol, '5m', limit=1000)\n",
        "        if ohlcv_best_sym:\n",
        "            df_best_sym = pd.DataFrame(ohlcv_best_sym, columns=['timestamp', 'open', 'high', 'low', 'close', 'volume'])\n",
        "            df_best_sym['timestamp'] = pd.to_datetime(df_best_sym['timestamp'], unit='ms')\n",
        "            df_best_sym = df_best_sym.set_index(pd.DatetimeIndex(df_best_sym['timestamp']))\n",
        "\n",
        "            # Obter os sinais do resultado do backtest\n",
        "            # Certificar-se de que os índices estão alinhados\n",
        "            signals_df = best_result.signals.copy()\n",
        "            signals_df.index = df_best_sym.index # Alinhar índices\n",
        "\n",
        "            # Preparar dados para mplfinance\n",
        "            mc = mpf.make_marketcolors(up='green', down='red', wick='inherit', edge='inherit', volume='in', ohlc='i')\n",
        "            s = mpf.make_mpf_style(marketcolors=mc, gridcolor='gray', gridstyle=':', y_on_right=False)\n",
        "\n",
        "            # Plotar gráfico de candlestick com sinais, volume e equity curve em subplots separados\n",
        "            # Usamos plt.figure() e add_gridspec() para controle preciso do layout\n",
        "            fig = plt.figure(figsize=(18, 16)) # Aumentar o tamanho para 3 subplots\n",
        "            gs = fig.add_gridspec(3, 1, height_ratios=[3, 1, 1]) # 3 rows, 1 col, ratio para cada linha\n",
        "\n",
        "            ax_main = fig.add_subplot(gs[0, 0]) # Gráfico OHLCV e Sinais\n",
        "            ax_volume = fig.add_subplot(gs[1, 0], sharex=ax_main) # Volume\n",
        "            ax_equity = fig.add_subplot(gs[2, 0], sharex=ax_main) # Curva de Equity\n",
        "\n",
        "            # Plotar OHLCV e volume usando mplfinance (sem o argumento addplot aqui)\n",
        "            mpf.plot(\n",
        "                df_best_sym,\n",
        "                type='candle',\n",
        "                ax=ax_main,\n",
        "                volume=ax_volume, # Especificar ax_volume para o volume\n",
        "                show_nontrading=False,\n",
        "                axtitle=f'{best_performing_symbol} - OHLCV com Sinais de Trade',\n",
        "                xrotation=0, # Evitar rotação padrão para melhor controle\n",
        "                style=s\n",
        "            )\n",
        "\n",
        "            # Plotar sinais manualmente no ax_main\n",
        "            # Sinais de Compra (LONG)\n",
        "            buy_signals_indices = signals_df[signals_df['signal_type'] == 'LONG'].index\n",
        "            if not buy_signals_indices.empty:\n",
        "                ax_main.scatter(\n",
        "                    buy_signals_indices, # Usar o índice datetime\n",
        "                    df_best_sym.loc[buy_signals_indices]['low'] * 0.99, # Posição abaixo da mínima\n",
        "                    marker='^',\n",
        "                    color='green',\n",
        "                    s=100,\n",
        "                    zorder=5 # Para garantir que os marcadores fiquem acima dos candles\n",
        "                )\n",
        "\n",
        "            # Sinais de Venda (SHORT)\n",
        "            sell_signals_indices = signals_df[signals_df['signal_type'] == 'SHORT'].index\n",
        "            if not sell_signals_indices.empty:\n",
        "                ax_main.scatter(\n",
        "                    sell_signals_indices, # Usar o índice datetime\n",
        "                    df_best_sym.loc[sell_signals_indices]['high'] * 1.01, # Posição acima da máxima\n",
        "                    marker='v',\n",
        "                    color='red',\n",
        "                    s=100,\n",
        "                    zorder=5\n",
        "                )\n",
        "\n",
        "            # Plotar curva de equity no ax_equity\n",
        "            ax_equity.plot(best_result.equity_curve, color='blue', label='Equity Curve')\n",
        "            ax_equity.set_title('Curva de Capital (Equity Curve)')\n",
        "            ax_equity.set_xlabel('Bar Index')\n",
        "            ax_equity.set_ylabel('Equity Multiplier')\n",
        "            ax_equity.grid(True)\n",
        "            ax_equity.legend()\n",
        "\n",
        "            plt.tight_layout() # Ajustar o layout para evitar sobreposição\n",
        "            plt.show() # Usar plt.show() para exibir a figura criada com subplots\n",
        "\n",
        "        else:\n",
        "            print(f\"Nenhum dado OHLCV encontrado para {best_performing_symbol}\")\n",
        "    except ccxt.NetworkError as e:\n",
        "        print(f\"Erro de rede ao buscar dados para {best_performing_symbol}: {e}\")\n",
        "    except ccxt.ExchangeError as e:\n",
        "        print(f\"Erro da exchange ao buscar dados para {best_performing_symbol}: {e}\")\n",
        "    except Exception as e:\n",
        "        print(f\"Ocorreu um erro inesperado ao processar {best_performing_symbol}: {e}\")\n",
        "else:\n",
        "    print(\"Nenhum backtest bem-sucedido encontrado para análise detalhada.\")"
      ],
