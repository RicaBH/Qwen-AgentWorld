      },
      "source": [
        "print(\"\\n--- Análise de Pares com Mais de 10 Trades ---\")\n",
        "\n",
        "pairs_with_sufficient_trades = [res for res in all_results if res[1].total_trades > 10]\n",
        "\n",
        "if pairs_with_sufficient_trades:\n",
        "    # Ordenar por R:R médio (decrescente para os melhores)\n",
        "    pairs_with_sufficient_trades.sort(key=lambda x: x[1].avg_rr, reverse=True)\n",
        "\n",
        "    print(f\"Encontrados {len(pairs_with_sufficient_trades)} pares com mais de 10 trades.\\n\")\n",
        "    print(\"| Símbolo       | Trades | Win Rate | Avg R:R |\")\n",
        "    print(\"|---------------|--------|----------|---------|\")\n",
        "    for sym, res in pairs_with_sufficient_trades:\n",
        "        # Corrigindo o formatador para win_rate\n",
        "        print(f\"| {sym:<13} | {res.total_trades:<6} | {f'{res.win_rate:.2%}':<8} | {res.avg_rr:.2f}R    |\")\n",
        "else:\n",
        "    print(\"Nenhum par encontrado com mais de 10 trades para análise.\")"
      ],
