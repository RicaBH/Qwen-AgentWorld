    {
      "cell_type": "markdown",
      "metadata": {
        "id": "51ac7ec3"
      },
      "source": [
        "## Otimização de `min_setup_score` para Maximizar o Fator de Lucro\n",
        "\n",
        "Vamos iterar sobre diferentes valores para o parâmetro `min_setup_score` e reexecutar o backtest para o par `BTC/USD` para encontrar o valor que resulta no maior Fator de Lucro."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "40251cb7",
        "outputId": "97e13d9f-7157-4443-da24-5cebe5ab1e2a"
      },
      "source": [
        "print(\"\\n--- Otimizando min_setup_score para BTC/USD ---\")\n",
        "\n",
        "# Definir um range de valores para min_setup_score para testar\n",
        "# O score máximo possível é 5, já que há 5 componentes no cálculo do score (sweep, killzone, fvg, flip, flow)\n",
        "score_values = range(1, 6) # Testar scores de 1 a 5\n",
        "\n",
        "results_optimization = []\n",
        "\n",
        "# Reutilizar df_btc_usd_new do backtest anterior\n",
        "# Certificar-se de que kraken_exchange esteja disponível no escopo\n",
        "\n",
        "for score in score_values:\n",
        "    print(f\"Testando min_setup_score = {score}...\")\n",
        "    # Criar uma nova instância de Params para cada iteração\n",
        "    current_params = Params(min_setup_score=score)\n",
        "\n",
        "    try:\n",
        "        # Re-fetch the OHLCV data for BTC/USD to ensure clean slate for each run\n",
        "        # Or use the existing df_btc_usd_new if it's guaranteed to be the same and not modified\n",
        "        # For consistency and to avoid potential side effects from previous runs, we'll re-fetch\n",
        "        ohlcv_btc_usd_opt = kraken_exchange.fetch_ohlcv(symbol_btc_usd, '5m', limit=1000)\n",
        "        if ohlcv_btc_usd_opt:\n",
        "            df_btc_usd_opt = pd.DataFrame(ohlcv_btc_usd_opt, columns=['timestamp', 'open', 'high', 'low', 'close', 'volume'])\n",
        "            df_btc_usd_opt['timestamp'] = pd.to_datetime(df_btc_usd_opt['timestamp'], unit='ms')\n",
        "            # No need to set index to datetime here, as run_backtest expects a 'timestamp' column or index\n",
        "\n",
        "            result_opt = run_backtest(df_btc_usd_opt, current_params)\n",
        "            results_optimization.append((score, result_opt))\n",
        "\n",
        "            print(f\"  min_setup_score = {score}: Profit Factor = {result_opt.profit_factor:.2f}, Total Trades = {result_opt.total_trades}\")\n",
        "        else:\n",
        "            print(f\"Nenhum dado OHLCV encontrado para {symbol_btc_usd} ao testar score {score}\")\n",
        "\n",
        "    except Exception as e:\n",
        "        print(f\"Ocorreu um erro ao executar o backtest para min_setup_score = {score}: {e}\")\n",
        "\n",
        "\n",
        "# Encontrar o melhor score\n",
        "best_score = None\n",
        "highest_profit_factor = -1.0 # Inicializar com um valor baixo\n",
        "\n",
        "print(\"\\n--- Resultados da Otimização ---\")\n",
        "for score, res in results_optimization:\n",
        "    if res.total_trades > 0 and res.profit_factor > highest_profit_factor:\n",
        "        highest_profit_factor = res.profit_factor\n",
        "        best_score = score\n",
        "    print(f\"Score: {score}, Profit Factor: {res.profit_factor:.2f}, Total Trades: {res.total_trades}\")\n",
        "\n",
        "if best_score is not None:\n",
        "    print(f\"\\nO melhor min_setup_score para maximizar o Profit Factor é: {best_score} (Profit Factor: {highest_profit_factor:.2f})\")\n",
        "else:\n",
        "    print(\"Não foi possível determinar o melhor min_setup_score (nenhum trade ou erro).\")\n"
      ],
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "\n",
            "--- Otimizando min_setup_score para BTC/USD ---\n",
            "Testando min_setup_score = 1...\n",
            "Ocorreu um erro ao executar o backtest para min_setup_score = 1: name 'kraken_exchange' is not defined\n",
            "Testando min_setup_score = 2...\n",
