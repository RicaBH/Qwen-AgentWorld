        "    ohlcv_btc_usd = kraken_exchange.fetch_ohlcv(symbol_btc_usd, '5m', limit=1000)\n",
        "\n",
        "    if ohlcv_btc_usd:\n",
        "        df_btc_usd = pd.DataFrame(ohlcv_btc_usd, columns=['timestamp', 'open', 'high', 'low', 'close', 'volume'])\n",
        "        df_btc_usd['timestamp'] = pd.to_datetime(df_btc_usd['timestamp'], unit='ms')\n",
        "        df_btc_usd = df_btc_usd.set_index('timestamp') # Set timestamp as index for consistency\n",
        "\n",
        "        # Run backtest for BTC/USD\n",
        "        result_btc_usd = run_backtest(df_btc_usd, params)\n",
        "\n",
        "        print(f\"Resultados para {symbol_btc_usd}:\")\n",
        "        print(f\"  Total Trades = {result_btc_usd.total_trades}\")\n",
        "        print(f\"  Win Rate = {result_btc_usd.win_rate:.2%}\")\n",
        "        print(f\"  Avg R:R = {result_btc_usd.avg_rr:.2f}\")\n",
        "        print(result_btc_usd.summary()) # Print the full summary\n",
        "\n",
        "        # Optionally, you can also add this result to your all_results list if you want it included in overall aggregates later\n",
        "        # all_results.append((symbol_btc_usd, result_btc_usd))\n",
        "\n",
        "    else:\n",
        "        print(f\"Nenhum dado OHLCV encontrado para {symbol_btc_usd}\")\n",
        "\n",
        "except ccxt.NetworkError as e:\n",
