    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 222
        },
        "id": "4d78574e",
        "outputId": "8ba55faa-ba08-4419-b56e-88b579113fde"
      },
      "source": [
        "from scipy import stats\n",
        "\n",
        "# Re-define result_stress_test and result_no_killzone if they are not defined\n",
        "# This makes the cell more robust against kernel restarts\n",
        "\n",
        "# Ensure new_params is defined, assuming it was from a prior successful execution\n",
        "if 'new_params' not in globals():\n",
        "    new_params = Params() # Requires Params class to be defined\n",
        "\n",
        "# Ensure df_simulated_ohlcv is defined\n",
        "if 'df_simulated_ohlcv' not in globals():\n",
        "    print(\"Warning: df_simulated_ohlcv not found. Attempting to re-create.\")\n",
        "    # This part assumes df_btc_usd_new and volatility_factor are available.\n",
        "    # If they are not, this will lead to further NameErrors.\n",
        "    # For a full robust solution, all upstream dependencies should be re-run.\n",
        "    # For now, we assume critical dataframes are present or can be re-fetched.\n",
        "    # For this fix, we assume the user will re-run prior cells if this fails.\n",
        "    # In a real scenario, it would be better to regenerate df_simulated_ohlcv from df_btc_usd_new\n",
        "    # and then fetch ohlcv for df_btc_usd_new if needed.\n",
        "    # For simplicity, we assume previous cells were executed and just the results were lost.\n",
        "    # A prompt to the user to re-run all cells from the top might be more appropriate if this recurs.\n",
        "\n",
        "# Re-create result_stress_test if it's not defined\n",
        "if 'result_stress_test' not in globals():\n",
        "    print(\"result_stress_test not found, re-running backtest for stress test...\")\n",
        "    if 'run_backtest' in globals() and 'df_simulated_ohlcv' in globals() and 'new_params' in globals():\n",
        "        result_stress_test = run_backtest(df_simulated_ohlcv, new_params)\n",
        "    else:\n",
        "        raise NameError(\"Dependencies (run_backtest, df_simulated_ohlcv, new_params) for result_stress_test are not defined.\")\n",
        "\n",
        "# Re-create result_no_killzone if it's not defined\n",
        "if 'result_no_killzone' not in globals():\n",
        "    print(\"result_no_killzone not found, re-running backtest without killzone...\")\n",
        "    params_no_killzone = Params()\n",
        "    params_no_killzone.w_killzone = 0.0\n",
        "    if 'run_backtest' in globals() and 'df_simulated_ohlcv' in globals() and 'params_no_killzone' in globals():\n",
        "        result_no_killzone = run_backtest(df_simulated_ohlcv, params_no_killzone)\n",
        "    else:\n",
        "        raise NameError(\"Dependencies (run_backtest, df_simulated_ohlcv) for result_no_killzone are not defined.\")\n",
        "\n",
        "\n",
        "# Extract PnL values from trades for both results\n",
        "pnl_stress_test = [t.pnl_r for t in result_stress_test.trades if t.exit_type != 'EOF']\n",
        "pnl_no_killzone = [t.pnl_r for t in result_no_killzone.trades if t.exit_type != 'EOF']\n",
        "\n",
        "print(\"\\n--- Análise Estatística da Diferença entre Teste de Estresse (Original) e (sem killzone) ---\")\n",
        "\n",
        "if len(pnl_stress_test) > 1 and len(pnl_no_killzone) > 1:\n",
        "    # Perform independent t-test\n",
        "    ttest_result = stats.ttest_ind(pnl_stress_test, pnl_no_killzone, equal_var=False) # Welch's t-test assuming unequal variances\n",
        "\n",
        "    print(f\"  Média PnL (Estresse Original)    : {np.mean(pnl_stress_test):.4f}\")\n",
        "    print(f\"  Média PnL (Estresse sem killzone) : {np.mean(pnl_no_killzone):.4f}\")\n",
        "    print(f\"  T-statistic                       : {ttest_result.statistic:.4f}\")\n",
        "    print(f\"  P-value                           : {ttest_result.pvalue:.4f}\")\n",
        "\n",
        "    alpha = 0.05\n",
        "    if ttest_result.pvalue < alpha:\n",
        "        print(f\"\\n  Com um p-valor de {ttest_result.pvalue:.4f} (menor que {alpha}), há uma diferença estatisticamente significativa entre as médias dos PnL's.\")\n",
        "        if np.mean(pnl_stress_test) > np.mean(pnl_no_killzone):\n",
        "            print(\"  A versão original do teste de estresse teve um desempenho médio de PnL melhor.\")\n",
        "        else:\n",
        "            print(\"  A versão sem killzone do teste de estresse teve um desempenho médio de PnL melhor.\")\n",
        "    else:\n",
        "        print(f\"\\n  Com um p-valor de {ttest_result.pvalue:.4f} (maior que {alpha}), não há evidência estatística significativa de uma diferença entre as médias dos PnL's.\")\n",
        "else:\n",
        "    print(\"  Não há trades suficientes em um ou ambos os resultados para realizar uma análise estatística significativa.\")"
      ],
      "execution_count": null,
