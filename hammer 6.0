      },
      "source": [
        "# Importar a biblioteca ccxt\n",
        "import ccxt\n",
        "\n",
        "# Exemplo de uso: carregar informações da Binance\n",
        "exchange = ccxt.binance()\n",
        "\n",
        "# Carregar mercados (pares de negociação)\n",
        "markets = exchange.load_markets()\n",
        "print(\"Mercados carregados da Binance:\", len(markets))\n",
        "\n",
        "# Acessar um mercado específico, por exemplo, BTC/USDT\n",
        "if 'BTC/USDT' in markets:\n",
        "    btc_usdt_market = markets['BTC/USDT']\n",
        "    print(\"Detalhes de BTC/USDT:\", btc_usdt_market)\n",
        "else:\n",
        "    print(\"BTC/USDT não encontrado nos mercados.\")\n"
      ],
      "execution_count": null,
