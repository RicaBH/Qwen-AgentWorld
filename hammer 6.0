    {
      "cell_type": "markdown",
      "metadata": {
        "id": "be263af2"
      },
      "source": [
        "### Fetching Historical Data for `BTC/USD`"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 443
        },
        "id": "430c74ad",
        "outputId": "5b7ca5cb-c770-49ce-e0ed-0eca79882e98"
      },
      "source": [
        "# Define the symbol for BTC/USD\n",
        "symbol_btc_usd = 'BTC/USD'\n",
        "\n",
        "print(f\"\\n--- Fetching OHLCV data for {symbol_btc_usd} to create df_btc_usd_new ---\")\n",
        "\n",
        "try:\n",
        "    ohlcv_btc_usd = kraken_exchange.fetch_ohlcv(symbol_btc_usd, '5m', limit=1000)\n",
        "\n",
        "    if ohlcv_btc_usd:\n",
        "        df_btc_usd_new = pd.DataFrame(ohlcv_btc_usd, columns=['timestamp', 'open', 'high', 'low', 'close', 'volume'])\n",
        "        df_btc_usd_new['timestamp'] = pd.to_datetime(df_btc_usd_new['timestamp'], unit='ms')\n",
        "        print(f\"Data for {symbol_btc_usd} fetched and stored in df_btc_usd_new.\")\n",
        "        display(df_btc_usd_new.head())\n",
        "    else:\n",
        "        print(f\"Nenhum dado OHLCV encontrado para {symbol_btc_usd}\")\n",
        "\n",
        "except ccxt.NetworkError as e:\n",
        "    print(f\"Erro de rede ao buscar dados para {symbol_btc_usd}: {e}\")\n",
        "except ccxt.ExchangeError as e:\n",
        "    print(f\"Erro da exchange ao buscar dados para {symbol_btc_usd}: {e}\")\n",
        "except Exception as e:\n",
        "    print(f\"Ocorreu um erro inesperado ao processar {symbol_btc_usd}: {e}\")"
      ],
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "\n",
            "--- Fetching OHLCV data for BTC/USD to create df_btc_usd_new ---\n"
          ]
        },
